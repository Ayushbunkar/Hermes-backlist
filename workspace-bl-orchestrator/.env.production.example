# -----------------------------------------------------------------------------
# Hermes Orchestrator - Production Environment Template
# Instructions: Copy this file to `.env` and fill in the values before starting.
# -----------------------------------------------------------------------------

# Telegram Bot Token (from BotFather)
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"

# Telegram Admin Chat ID (the user/group to send leads to)
TELEGRAM_ADMIN_CHAT_ID="your_telegram_chat_id_here"

# PostgreSQL Connection URL
# Example: postgresql://postgres:password@localhost:5432/hermes
DB_URL="postgresql://user:password@localhost:5432/dbname"

# Daemon Settings
# Space separated list of subreddits or domains to exclude
BLACKLISTED_SUBREDDITS="AskReddit funny pics"

_score\": 9.5,\n      \"traffic_estimate\": \"medium\",\n      \"freshness_score\": 6,\n      \"contextual_fit\": 9,\n      \"posting_ease\": \"manual_review\",\n      \"recommendation\": \"high_priority\",\n      \"audit_notes\": \"An established, active cryptocurrency news portal with solid domain authority. Provides highly valuable, relevant links with great visibility for coinography.com.\"\n    },\n    {\n      \"url\": \"https://icoshock.com/submit-guest-post\",\n      \"domain\": \"icoshock.com\",\n      \"type\": \"guest_post\",\n      \"submission_url\": \"https://icoshock.com/submit-guest-post\",\n      \"target_title\": \"Submit a Crypto Guest Post -\",\n      \"target_excerpt\": \"re that there is a $30 fee for publishing a post. Guidelines for Crypto, ICO, or Blockchain-Related Guest Posts We aim for fresh, exciting content at ICOshock, but it should also be objective. Therefore, all users must familiarize themselves with and follow these guidelines: Ethics : Do not write posts or formulations that are abusive, racist, thre\",\n      \"opportunity_context\": \"Direct portal to submit a guest article about cryptocurrency, Web3, or new projects.\",\n      \"opportunity_freshness\": \"evergreen\",\n      \"posting_action\": \"outreach_email\",\n      \"score\": 5.8,\n      \"domain_authority\": 20,\n      \"dofollow\": true,\n      \"spam_score\": \"medium\",\n      \"relevance_score\": 8.5,\n      \"traffic_estimate\": \"low\",\n      \"freshness_score\": 5,\n      \"contextual_fit\": 8,\n      \"posting_ease\": \"manual_review\",\n      \"recommendation\": \"low\",\n      \"audit_notes\": \"Charges a flat $30 publication fee. While the niche fit is good, paid links carry a higher risk profile and lower natural organic value.\"\n    },\n    {\n      \"url\": \"https://cryptoslate.com/directory\",\n      \"domain\": \"cryptoslate.com\",\n      \"type\": \"directory\",\n      \"submission_url\": \"https://cryptoslate.com/directory\",\n      \"target_title\"
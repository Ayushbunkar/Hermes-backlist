\"type\": \"directory\",\n      \"title\": \"Memecoinist on CryptoSlate\",\n      \"content\": \"Memecoinist is a premier news and community hub dedicated to the fast-paced world of meme coins. We provide the latest updates, launches, and insights on everything from Dogecoin to Shiba Inu, making us the go-to resource for enthusiasts and investors.\",\n      \"backlink_url\": \"memecoinist.com\",\n      \"backlink_anchor_text\": \"Memecoinist\",\n      \"image_path\": null,\n      \"submission_instructions\": \"Submit profile for editorial review.\"\n    },\n    {\n      \"site_url\": \"https://coincodex.com\",\n      \"site_domain\": \"coincodex.com\",\n      \"type\": \"directory\",\n      \"title\": \"Memecoinist on CoinCodex\",\n      \"content\": \"Your essential guide to the meme coin universe. Memecoinist offers real-time news, launch alerts, and community discussions for popular and emerging meme-based cryptocurrencies. Track the next big thing at memecoinist.com.\",\n      \"backlink_url\": \"memecoinist.com\",\n      \"backlink_anchor_text\": \"memecoinist.com\",\n      \"image_path\": null,\n      \"submission_instructions\": \"Submit project for directory listing.\"\n    },\n    {\n      \"site_url\": \"https://coinpaprika.com\",\n      \"site_domain\": \"coinpaprika.com\",\n      \"type\": \"directory\",\n      \"title\": \"Memecoinist on Coinpaprika\",\n      \"content\": \"Memecoinist is a dedicated platform for meme coin news and launches. We cover the latest trends, from established players like Doge to the newest market entries, providing a comprehensive overview for the community.\",\n      \"backlink_url\": \"memecoinist.com\",\n      \"backlink_anchor_text\": \"Memecoinist\",\n      \"image_path\": null,\n      \"submission_instructions\": \"Add coin to the database for indexing.\"\n    },\n    {\n      \"site_url\": \"https://coincheckup.com\",\n      \"site_domain\": \"coincheckup.com\",\n      \"type\": \"directory\",\n      \"title\": \"Memecoinist on CoinCheckup\",\n      \"content\": \"Stay ahead in the meme coin market with Memecoinist. We deliver timely news, analysis, and launch details for the meme coin niche, helping you follow the journey of coins like SHIB and Doge.\",\n      \"backlink_url\": \"memecoinist.com\",\n      \"backlink_anchor_text\": \"Memecoinist\",\n      \"image_path\": null,\n      \"submission_instructions\": \"Submit project for analysis and listing.\"\n    },\n    {\n      \"site_url\": \"https://icomarks.com\",\n      \"site_domain\": \"icomarks.com\",\n      \"type\": \"directory\",\n      \"title\": \"Memecoinist on ICOmarks\",\n      \"content\": \"Memecoinist is the leading source for news and information on meme coin launches. Discover new projects, follow market trends, and engage with a vibrant community of meme coin fans.\",\n      \"backlink_url\": \"memecoinist.com\",\n      \"backlink_anchor_text\": \"Memecoinist\",\n      \"image_path\": null,\n      \"submission_instructions\": \"Submit project to the ICOmarks database.\"\n    },\n    {\n      \"site_url\": \"https://cryptototem.com\",\n      \"site_domain\": \"cryptototem.com\",\n      \"type\": \"directory\",\n      \"title\": \"Memecoinist on CryptoTotem\",\n      \"content\": \"The ultimate destination for meme coin aficionados. Memecoinist provides up-to-the-minute news, project launches, and community insights for the entire meme coin ecosystem, from Doge to the latest viral tokens.\",\n      \"backlink_url\": \"memecoinist.com\",\n      \"backlink_anchor_text\": \"Memecoinist\",\n      \"image_path\": null,\n      \"submission_instructions\": \"Add project to the listing database.\"\n    },\n    {\n      \"site_url\": \"https://coinmooner.com\",\n      \"site_domain\": \"coinmooner.com\",\n      \"type\": \"directory\",\n      \"title\": \"Memecoinist on Coinmooner\",\n      \"content\": \"Memecoinist is your launchpad for the latest meme coins. We bring you breaking news, community voting, and launch information for the most exciting new projects in the meme coin space. Join us at memecoinist.com to catch the next moonshot.\",\n      \"backlink_url\": \"memecoinist.com\",\n      \"backlink_anchor_text\": \"memecoinist.com\",\n      \"image_path\": null,\n      \"submission_instructions\": \"Submit coin for community voting.\"\n    },\n    {\n      \"site_url\": \"https://coinhunt.cc\",\n      \"site_domain\": \"coinhunt.cc\",\n      \"type\": \"directory\",\n      \"title\": \"Memecoinist on Coinhunt\",\n      \"content\": \"Hunt for the next meme coin gem with Memecoinist. We are a news and launch platform focused on the meme coin market, providing the latest on Doge, Shiba Inu, and a host of new contenders.\",\n      \"backlink_url\": \"memecoinist.com\",\n      \"backlink_anchor_text\": \"Memecoinist\",\n      \"image_path\": null,\n      \"submission_instructions\": \"Submit coin for visibility and community hunting.\"\n    },\n    {\n      \"site_url\": \"https://coinvote.cc\",\n      \"site_domain\": \"coinvote.cc\",\n      \"type\": \"directory\",\n      \"title\": \"Memecoinist on Coinvote\",\n      \"content\": \"Cast your vote for the hottest new meme coins at Memecoinist. We are a community-driven news and launch site dedicated to the world of meme-based cryptocurrencies. Find and vote for your favorites at memecoinist.com.\",\n      \"backlink_url\": \"memecoinist.com\",\n      \"backlink_anchor_text\": \"memecoinist.com\",\n      \"image_path\": null,\n      \"submission_instructions\": \"Add your coin to the voting list.\"\n    }\n  ]\n}"}}],"api":"openai-completions","provider":"local-bifrost","model":"gemini-2.5-pro","usage":{"input":2043,"output":2445,"cacheRead":4529,"cacheWrite":0,"totalTokens":9017,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1780744096441,"responseId":"oP8jauiIIYfzv_gPg6bzuAY"}}

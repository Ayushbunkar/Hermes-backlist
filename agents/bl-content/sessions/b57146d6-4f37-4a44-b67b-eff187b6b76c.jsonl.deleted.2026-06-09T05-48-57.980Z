: \"directory\",\n      \"score\": 4.8,\n      \"domain_authority\": 20,\n      \"dofollow\": false,\n      \"spam_score\": \"medium\",\n      \"relevance_score\": 7,\n      \"traffic_estimate\": \"low\",\n      \"recommendation\": \"low\",\n      \"audit_notes\": \"A specialized directory for crypto platforms and exchanges. Useful for initial domain diversity, but directory lists have lower authority and typically use nofollow links.\"\n    },\n    {\n      \"url\": \"https://dexterlab.com/best-crypto-resources-list/\",\n      \"domain\": \"dexterlab.com\",\n      \"type\": \"resource_page\",\n      \"score\": 8.5,\n      \"domain_authority\": 42,\n      \"dofollow\": true,\n      \"spam_score\": \"low\",\n      \"relevance_score\": 9,\n      \"traffic_estimate\": \"medium\",\n      \"recommendation\": \"high_priority\",\n      \"audit_notes\": \"A clean and reputable crypto educational resource page with quality inbound profiles. Suggesting our tool here is highly relevant and likely to pass clean link equity.\"\n    },\n    {\n      \"url\": \"https://www.cryptoresearchportal.com/crypto-resources\",\n      \"domain\": \"cryptoresearchportal.com\",\n      \"type\": \"resource_page\",\n      \"score\": 8.1,\n      \"domain_authority\": 35,\n      \"dofollow\": true,\n      \"spam_score\": \"low\",\n      \"relevance_score\": 9,\n      \"traffic_estimate\": \"medium\",\n      \"recommendation\": \"high_priority\",\n      \"audit_notes\": \"An extensive curated repository of crypto directories and tools. Highly relevant target with clean editorial quality and contextual value.\"\n    },\n    {\n      \"url\": \"https://bitcoinwiki.org/wiki/cryptocurrency-resources-list\",\n      \"domain\": \"bitcoinwiki.org\",\n      \"type\": \"resource_page\",\n      \"score\": 8.8,\n      \"domain_authority\": 60,\n      \"dofollow\": false,\n      \"spam_score\": \"low\",\n      \"relevance_score\": 10,\n      \"traffic_estimate\": \"high\",\n      \"recommendation\": \"high_priority\",\n      \"audit_notes\": \"A highly authoritative wiki platform with high traffic. Even if the links are nofollow, a link from a premium crypto wiki drives massive trust and referral traffic.\"\n    },\n    {\n      \"url\": \"https://www.thecryptonetwork.com/getting-started-with-cryptocurrency/the-crypto-directory/add-link.html\",\n      \"domain\": \"thecryptonetwork.com\",\n      \"type\": \"directory\",\n      \"score\": 4.2,\n      \"domain_authority\": 18,\n      \"dofollow\": false,\n      \"spam_score\": \"medium\",\n      \"relevance_score\": 7,\n      \"traffic_estimate\": \"low\",\n      \"recommendation\": \"low\",\n      \"audit_notes\": \"A public submit-a-link crypto directory. Very easy submission process but offers minimal link power due to lower authority and high probability of nofollow tags.\"\n    }\n  ]\n}"}],"isError":false,"timestamp":1780741494451}}

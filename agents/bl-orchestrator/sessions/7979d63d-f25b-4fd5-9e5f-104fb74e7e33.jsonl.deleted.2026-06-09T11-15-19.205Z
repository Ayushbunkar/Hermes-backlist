talk.org/index.php?topic=5584552.0\",\n      \"domain\": \"bitcointalk.org\",\n      \"type\": \"forum_reply\",\n      \"title\": \"Strategy Sells 32 BTC for $2.5M\",\n      \"snippet\": \"Discussion on institutional selling of Bitcoin.\",\n      \"score_100\": 42.75,\n      \"host_usability\": 12.5,\n      \"rank\": 4\n    },\n    {\n      \"url\": \"https://bitcointalk.org/index.php?topic=5583349.0\",\n      \"domain\": \"bitcointalk.org\",\n      \"type\": \"forum_reply\",\n      \"title\": \"Bitcoin Is risky... But living on fiat is riskier\",\n      \"snippet\": \"Discussion comparing risk of Bitcoin to fiat currencies.\",\n      \"score_100\": 42.75,\n      \"host_usability\": 12.5,\n      \"rank\": 5\n    }\n  ]\n}"}],"isError":false,"timestamp":1781003280291}}
